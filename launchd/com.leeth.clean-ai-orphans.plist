<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.leeth.clean-ai-orphans</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>__HOME__/bin/clean-ai-orphans.sh</string>
__EXTRA_PROGRAM_ARGUMENTS__
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>600</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/clean-ai-orphans.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/clean-ai-orphans.log</string>
</dict>
</plist>
